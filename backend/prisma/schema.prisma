datasource db {
  provider = "postgresql"
  url      = env("postgresql://neondb_owner:npg_XWTnHKwte87F@ep-raspy-firefly-ateyii5l.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Incident {
  id           String      @id
  serviceName  String
  severity     String
  status       String
  startedAt    DateTime
  rawAlertText String
  source       String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  reports      RCAReport[]
}

model RCAReport {
  id              String       @id @default(uuid())
  incidentId      String
  incident        Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  timeline        String
  rootCause       String
  blastRadius     String
  confidenceScore Int
  modelUsed       String?
  actionItems     ActionItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ActionItem {
  id          String     @id @default(uuid())
  reportId    String
  report      RCAReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  incidentId  String
  title       String
  description String
  severity    String
  status      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
"scripts": {
  "dev": "tsx watch src/server.ts",
  "postinstall": "node ./node_modules/.bin/prisma generate",
  "build": "tsc",
  "start": "node dist/server.js",
  "db:migrate": "prisma migrate dev",
  "db:studio": "prisma studio"
}